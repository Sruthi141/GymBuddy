{
  "name": "gymbuddy-backend",
  "version": "1.0.0",
  "description": "GymBuddy API Server - Location-based gym partner matching platform",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
